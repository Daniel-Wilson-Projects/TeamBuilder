<g:each var="node" in="${hierarchy}"><g:if test="${node?.PARENT_NODE_ID == null}">${node.id}[${node.spriden_first_name} ${node.spriden_last_name}<g:each var="pRoles" in="${personsRolesList}"><g:if test="${pRoles.pidm.toString() == node.SPRIDEN_PIDM.toString()}"><div><span>${pRoles.ROLE_NAME}</span></div></g:if></g:each>]${'\n'}</g:if><g:else>${node?.PARENT_NODE_ID} --> ${node.id}[${node.spriden_first_name} ${node.spriden_last_name}<g:each var="pRoles" in="${personsRolesList}"><g:if test="${pRoles.pidm.toString() == node.SPRIDEN_PIDM.toString()}"><div><span>${pRoles.ROLE_NAME}</span></div></g:if></g:each>]${'\n'}</g:else></g:each>
<g:each var="clickNode" in="${hierarchy}">click ${clickNode.id} call modelToggle(${clickNode.id}, ${clickNode.pidm}) "Click"${'\n'} </g:each>
